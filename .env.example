# ChatHR Environment Variables
# Copy this file to .env and fill in real values. Never commit .env to git.

# Database
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=chathr
POSTGRES_USER=chathr_user
POSTGRES_PASSWORD=CHANGE_ME

# Redis
REDIS_URL=redis://redis:6379

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=chathr-docs

# OpenRouter (LLM Gateway)
OPENROUTER_API_KEY=CHANGE_ME
OPENROUTER_DEFAULT_MODEL=anthropic/claude-3-haiku
OPENROUTER_FALLBACK_MODEL=openai/gpt-4o-mini
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# Auth
JWT_SECRET=CHANGE_ME
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# API
API_HOST=0.0.0.0
API_PORT=8000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
