# ChatHR Environment Variables
# Copy this file to .env for local development. Never commit .env to git.
# All values here are safe dev placeholders — replace before any non-local deployment.

# Database
POSTGRES_DB=chathr
POSTGRES_USER=chathr_user
POSTGRES_PASSWORD=chathr_dev
DATABASE_URL=postgresql://chathr_user:chathr_dev@postgres:5432/chathr

# Redis
REDIS_URL=redis://redis:6379

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=chathr-docs
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_DOCUMENTS=chathr-documents
MINIO_SECURE=false

# LLM Gateway — all model calls must go through the gateway with privacy guard
# LLM_PROVIDER=fake-local: deterministic, no external calls (default for dev/tests)
# LLM_PROVIDER=openrouter: requires OPENROUTER_API_KEY; not active by default
LLM_PROVIDER=fake-local
OPENROUTER_API_KEY=REPLACE_WITH_REAL_KEY_FOR_OPENROUTER
DEFAULT_CHAT_MODEL=anthropic/claude-haiku-4-5-20251001
FALLBACK_CHAT_MODEL=openai/gpt-4o-mini
LLM_REQUEST_TIMEOUT_SECONDS=30

# Embedding provider
# Use fake-local for dev/tests (no external calls, deterministic).
EMBEDDING_PROVIDER=fake-local
EMBEDDING_DIMENSION=16
EMBEDDING_MODEL=fake-local-v1

# Auth (JWT — local MVP only, not production SSO)
JWT_SECRET_KEY=dev-jwt-secret-key-do-not-use-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Initial admin bootstrap (used by scripts/create_initial_admin.py)
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=admin_dev_password

# RAG retrieval
CHAT_RETRIEVAL_TOP_K=8

# API
API_HOST=0.0.0.0
API_PORT=8000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
