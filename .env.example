# ChatHR Environment Variables
# Copy this file to .env and fill in real values. Never commit .env to git.

# Database
POSTGRES_DB=chathr
POSTGRES_USER=chathr_user
POSTGRES_PASSWORD=CHANGE_ME
DATABASE_URL=postgresql://chathr_user:CHANGE_ME@postgres:5432/chathr

# Redis
REDIS_URL=redis://redis:6379

# MinIO
MINIO_ROOT_USER=CHANGE_ME
MINIO_ROOT_PASSWORD=CHANGE_ME
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=chathr-docs
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET_DOCUMENTS=chathr-documents
MINIO_SECURE=false

# LLM Gateway — all model calls must go through the gateway with privacy guard
# LLM_PROVIDER=fake-local: deterministic, no external calls (default for dev/tests)
# LLM_PROVIDER=openrouter: requires OPENROUTER_API_KEY; not active by default
LLM_PROVIDER=fake-local
OPENROUTER_API_KEY=CHANGE_ME
DEFAULT_CHAT_MODEL=anthropic/claude-haiku-4-5-20251001
FALLBACK_CHAT_MODEL=openai/gpt-4o-mini
LLM_REQUEST_TIMEOUT_SECONDS=30

# Embedding provider
# Use fake-local for dev/tests (no external calls, deterministic).
# Real providers (OpenRouter, etc.) are future work and must pass through
# the LLM Gateway privacy guard before any text is sent externally.
EMBEDDING_PROVIDER=fake-local
EMBEDDING_DIMENSION=16
EMBEDDING_MODEL=fake-local-v1

# Auth (JWT — local MVP only, not production SSO)
JWT_SECRET_KEY=CHANGE_ME_USE_A_LONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Initial admin bootstrap (used by scripts/create_initial_admin.py)
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=CHANGE_ME

# API
API_HOST=0.0.0.0
API_PORT=8000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
