# ChatHR Environment Variables
# Copy this file to .env and fill in real values. Never commit .env to git.

# Database
POSTGRES_DB=chathr
POSTGRES_USER=chathr_user
POSTGRES_PASSWORD=CHANGE_ME
DATABASE_URL=postgresql://chathr_user:CHANGE_ME@postgres:5432/chathr

# Redis
REDIS_URL=redis://redis:6379

# MinIO
MINIO_ROOT_USER=CHANGE_ME
MINIO_ROOT_PASSWORD=CHANGE_ME
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=chathr-docs

# LLM Models (via OpenRouter)
OPENROUTER_API_KEY=CHANGE_ME
DEFAULT_CHAT_MODEL=anthropic/claude-3-haiku
FALLBACK_CHAT_MODEL=openai/gpt-4o-mini
EMBEDDING_MODEL=openai/text-embedding-3-small

# Auth
JWT_SECRET=CHANGE_ME
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# API
API_HOST=0.0.0.0
API_PORT=8000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
